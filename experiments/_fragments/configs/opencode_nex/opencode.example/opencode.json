{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "enabled_providers": ["nex"],
  "model": "nex/replace_with_nex_model_id",
  "small_model": "nex/replace_with_nex_small_model_id",
  "permission": "allow",
  "provider": {
    "nex": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Nex",
      "options": {
        "baseURL": "replace_with_nex_base_url",
        "apiKey": "replace_with_nex_api_key"
      },
      "models": {
        "replace_with_nex_model_id": {
          "name": "replace_with_nex_model_id"
        },
        "replace_with_nex_small_model_id": {
          "name": "replace_with_nex_small_model_id"
        }
      }
    }
  }
}
